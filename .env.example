# Shift Manager - Environment Variables Template
# Copy this file to .env and fill in the values for local development.
# IMPORTANT: Never commit your actual .env file to version control.

# ── Backend Configuration ─────────────────────────────────────────────────────

# Environment (Development / Production)
ASPNETCORE_ENVIRONMENT=Development

# JWT Security Key - Required (Min 32 chars for HS256)
JWT_KEY=your_super_secret_key_minimum_32_characters_long

# SQL Server Connection String
# For local: Server=localhost;Database=ShiftManagerDB;Trusted_Connection=True;TrustServerCertificate=True
DB_CONNECTION=Server=YOUR_HOST;Database=YOUR_DB;User Id=YOUR_USER;Password=YOUR_PASSWORD;

# Allowed CORS Origins (Comma separated)
CORS_ORIGINS=http://localhost:5173,https://localhost:7020

# ── Frontend Configuration ────────────────────────────────────────────────────

# API Base URL (Used by Vite during development and build)
VITE_API_URL=http://localhost:5020/api
