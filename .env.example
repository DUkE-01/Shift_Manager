# ============================================================
# Shift Manager — Local development environment template
# Copy this file to .env (one level above the .csproj) and fill
# in real values. The .env file is in .gitignore — never commit it.
# ============================================================

# SQL Server connection string
# Format: Server=<host>;Database=<db>;User Id=<user>;Password=<pass>;TrustServerCertificate=True
ConnectionStrings__DefaultConnection=Server=localhost;Database=ShiftManagerDB;Trusted_Connection=True;TrustServerCertificate=True

# JWT — generate with: openssl rand -base64 64
# Must be at least 32 characters. Keep secret!
JWT__KEY=CHANGE_ME_minimum_32_chars_long_random_string
JWT__ISSUER=ShiftManagerAPI
JWT__AUDIENCE=ShiftManagerClient
JWT__AccessTokenExpiryMinutes=15
JWT__RefreshTokenExpiryDays=7

# CORS
CORS__AllowedOrigins__0=http://localhost:5173
CORS__AllowedOrigins__1=https://localhost:5173
